# Attractor Environment Configuration
# Copy this file to .env and customize for your deployment

# -----------------------------------------------------------------------------
# Server Configuration
# -----------------------------------------------------------------------------
SERVER_HOST=0.0.0.0
SERVER_PORT=3000
NODE_ENV=production

# -----------------------------------------------------------------------------
# Redis Configuration
# -----------------------------------------------------------------------------
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# -----------------------------------------------------------------------------
# Storage Paths (in container)
# -----------------------------------------------------------------------------
ARTIFACTS_DIR=/app/data/artifacts
LOGS_DIR=/app/logs
CHECKPOINTS_DIR=/app/checkpoints

# -----------------------------------------------------------------------------
# Coordinator Configuration
# -----------------------------------------------------------------------------
COORDINATOR_ENABLED=true

# -----------------------------------------------------------------------------
# LLM Providers (at least one required)
# -----------------------------------------------------------------------------
# Anthropic
ANTHROPIC_API_KEY=

# OpenAI
OPENAI_API_KEY=

# Kilo Gateway
KILO_API_KEY=
KILO_CONFIG=balanced

# -----------------------------------------------------------------------------
# Security
# -----------------------------------------------------------------------------
CORS_ORIGIN=*

# -----------------------------------------------------------------------------
# Feature Flags
# -----------------------------------------------------------------------------
ENABLE_CHECKPOINTING=true
ENABLE_VALIDATION=true
