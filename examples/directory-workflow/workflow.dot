digraph Example {
    rankdir=LR;
    
    // Start node
    start [shape=Mdiamond label="Start" type="start"];
    
    // Tool node with prompt from file
    analyze [shape=box label="Analyze" type="tool"];
    
    // Parallel node with prompts from files
    process [shape=box label="Process" type="parallel"];
    
    // FanIn node that consolidates results
    consolidate [shape=tripleoctagon label="Consolidate" type="parallel.fan_in"];
    
    // Exit node
    exit [shape=Msquare label="Exit" type="exit"];
    
    // Edges
    start -> analyze;
    analyze -> process;
    process -> consolidate;
    consolidate -> exit;
}