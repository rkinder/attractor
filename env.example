# Attractor Server Configuration
# Copy this file to .env and customize as needed

# =============================================================================
# Server Configuration
# =============================================================================

# Server port (default: 3000)
SERVER_PORT=3000

# Node environment (development, production)
NODE_ENV=production

# =============================================================================
# Storage Configuration
# =============================================================================

# Local state directory
STATE_DIR=./data/state

# Artifacts directory
ARTIFACTS_DIR=./data/artifacts

# Logs directory
LOGS_DIR=./logs

# Checkpoints directory
CHECKPOINTS_DIR=./checkpoints

# =============================================================================
# Redis Configuration (optional - for distributed coordination)
# =============================================================================

# Enable Redis (default: false)
REDIS_ENABLED=false
REDIS_HOST=localhost
REDIS_PORT=6379

# =============================================================================
# LLM Provider Configuration
# =============================================================================

# LM Studio (local)
LMSTUDIO_BASE_URL=http://10.0.2.2:1234/v1
LMSTUDIO_MODEL=qwen/qwen3.5-9b
LMSTUDIO_API_KEY=lm-studio

# Or use Anthropic
# ANTHROPIC_API_KEY=sk-ant-...

# Or use OpenAI
# OPENAI_API_KEY=sk-...

# =============================================================================
# Coordinator Configuration
# =============================================================================

# Enable coordinator (default: true)
COORDINATOR_ENABLED=true

# =============================================================================
# Docker/Deployment Configuration
# =============================================================================

# Output directory for generated code (mounted into container)
# For docker: set to your target repo path, e.g., /path/to/your/project
# Files written to this directory will appear on host filesystem
GENERATED_DIR=./generated
